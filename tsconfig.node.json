{
    "exclude": ["node_modules"],
    "include": ["./vite.config.ts", "packages/**/vite.config.ts"],
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "composite": true,
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "skipLibCheck": true,
        "strict": true,
        "types": ["node"]
    }
}
