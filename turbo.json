{
    "$schema": "https://turbo.build/schema.json",
    "cacheMaxAge": "1s",
    "ui": "stream",
    "globalDependencies": [
        ".env",
        "package.json",
        "pnpm-lock.yaml",
        "tsconfig.json",
        "vite.config.ts",
        "packages/**/vite.config.ts"
    ],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "!.next/cache/**", "dist/**", "lib/**", "out/**"]
        },
        "clean": {
            "cache": false
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "start": {
            "dependsOn": ["^build"],
            "persistent": true
        },
        "typecheck": {
            "cache": false,
            "dependsOn": ["^typecheck"]
        }
    }
}
