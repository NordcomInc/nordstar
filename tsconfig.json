{
    "$schema": "https://json.schemastore.org/tsconfig.json",
    "include": ["packages", "./packages/**/src/**/*", "./@types/declaration.d.ts"],
    "compilerOptions": {
        "allowJs": false,
        "allowSyntheticDefaultImports": true,
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "forceConsistentCasingInFileNames": true,
        "incremental": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "lib": ["ESNext", "DOM", "DOM.Iterable", "Decorators"],
        "module": "ESNext",
        "moduleDetection": "force",
        "moduleResolution": "Bundler",
        "noFallthroughCasesInSwitch": true,
        "noImplicitAny": true,
        "noUncheckedIndexedAccess": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "removeComments": false,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "strictBindCallApply": true,
        "strictFunctionTypes": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": true,
        "target": "ESNext",
        "useDefineForClassFields": true,
        "paths": {
            "@nordcom/nordstar": ["./packages/core/nordstar"],
            "@nordcom/nordstar-accented": ["./packages/components/accented"],
            "@nordcom/nordstar-accordion": ["./packages/components/accordion"],
            "@nordcom/nordstar-button": ["./packages/components/button"],
            "@nordcom/nordstar-card": ["./packages/components/card"],
            "@nordcom/nordstar-details": ["./packages/components/details"],
            "@nordcom/nordstar-dropdown-menu": ["./packages/components/dropdown-menu"],
            "@nordcom/nordstar-header": ["./packages/components/header"],
            "@nordcom/nordstar-heading": ["./packages/components/heading"],
            "@nordcom/nordstar-input": ["./packages/components/input"],
            "@nordcom/nordstar-kbd": ["./packages/components/kbd"],
            "@nordcom/nordstar-label": ["./packages/components/label"],
            "@nordcom/nordstar-select": ["./packages/components/select"],
            "@nordcom/nordstar-separator": ["./packages/components/separator"],
            "@nordcom/nordstar-switch": ["./packages/components/switch"],
            "@nordcom/nordstar-system": ["./packages/core/system"],
            "@nordcom/nordstar-tooltip": ["./packages/components/tooltip"],
            "@nordcom/nordstar-view": ["./packages/components/view"]
        }
    },
    "exclude": [
        "**/.turbo",
        "**/*.config.*",
        "**/*.stories.*",
        "**/*.test.*",
        "**/coverage",
        "**/dist",
        "**/node_modules",
        "**/src/**/*.d.ts",
        "node_modules"
    ],
    "references": [
        {
            "path": "./tsconfig.node.json"
        }
    ]
}
