{
    "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
    "description": "Repo-local Claude Code plugins for the nordstar monorepo.",
    "name": "nordstar-plugins",
    "owner": {
        "email": "dev@nordcom.io",
        "name": "Nordcom"
    },
    "plugins": [
        {
            "category": "development",
            "description": "Tailwind CSS LSP for Claude Code - completions, hover info, and diagnostics for Tailwind classes.",
            "name": "tailwind-lsp-adapter",
            "source": "./tailwind-lsp-adapter",
            "strict": false,
            "version": "1.0.0",
            "author": {
                "email": "dev@nordcom.io",
                "name": "Nordcom"
            },
            "lspServers": {
                "tailwindcss": {
                    "command": "pnpm",
                    "args": [
                        "dlx",
                        "--package",
                        "tailwind-lsp-adapter@1.1.5",
                        "--package",
                        "@tailwindcss/language-server@0.14.29",
                        "tailwind-lsp-adapter"
                    ],
                    "extensionToLanguage": {
                        ".css": "css",
                        ".html": "html",
                        ".less": "less",
                        ".scss": "scss",
                        ".svelte": "svelte",
                        ".vue": "vue"
                    }
                }
            }
        },
        {
            "category": "development",
            "description": "TypeScript/JavaScript LSP for Claude Code - go-to-definition, find references, hover, and diagnostics.",
            "name": "typescript-lsp",
            "source": "./typescript-lsp",
            "strict": false,
            "version": "1.0.0",
            "author": {
                "email": "dev@nordcom.io",
                "name": "Nordcom"
            },
            "lspServers": {
                "typescript": {
                    "args": ["dlx", "typescript-language-server@4.4.1", "--stdio"],
                    "command": "pnpm",
                    "extensionToLanguage": {
                        ".cjs": "javascript",
                        ".cts": "typescript",
                        ".js": "javascript",
                        ".jsx": "javascriptreact",
                        ".mjs": "javascript",
                        ".mts": "typescript",
                        ".ts": "typescript",
                        ".tsx": "typescriptreact"
                    }
                }
            }
        }
    ]
}
