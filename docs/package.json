{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/nordstar-docs",
    "sideEffects": false,
    "private": true,
    "type": "module",
    "version": "0.2.1",
    "cacheDirectories": [
        ".next/cache"
    ],
    "scripts": {
        "build": "next build",
        "dev": "next dev",
        "clean": "rm -rf dist coverage .turbo .next *.tsbuildinfo *.log",
        "generate": "concurrently -i pnpm:generate:examples pnpm:generate:props pnpm:generate:changelogs",
        "generate:changelogs": "tsx scripts/generate-changelogs.ts",
        "generate:examples": "tsx scripts/generate-examples.ts",
        "generate:props": "tsx scripts/generate-props.ts",
        "predev": "pnpm generate",
        "prebuild": "pnpm generate",
        "start": "next start -p $PORT",
        "pretypecheck": "pnpm generate",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "nordstar",
        "nordcom",
        "docs"
    ],
    "author": {
        "name": "Filiph Sandström",
        "email": "filfat@hotmail.se",
        "url": "https://github.com/filiphsps/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/NordcomInc/nordstar.git",
        "directory": "docs"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/NordcomInc/nordstar/issues"
    },
    "homepage": "https://nordcominc.github.io/nordstar/",
    "dependencies": {
        "@mdx-js/loader": "3.1.1",
        "@mdx-js/react": "3.1.1",
        "@next/mdx": "16.2.9",
        "@nordcom/nordstar": "workspace:*",
        "clsx": "2.1.1",
        "geist": "1.7.2",
        "next": "16.2.9",
        "next-mdx-remote": "6.0.0",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "rehype": "13.0.2",
        "rehype-autolink-headings": "7.1.0",
        "rehype-parse": "9.0.1",
        "rehype-pretty-code": "0.14.3",
        "rehype-slug": "6.0.0",
        "remark": "15.0.1",
        "remark-gfm": "4.0.1",
        "shiki": "4.2.0",
        "tailwind-merge": "3.6.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "4.3.1",
        "@types/mdx": "2.0.14",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "concurrently": "10.0.3",
        "globals": "17.7.0",
        "postcss": "8.5.15",
        "postcss-load-config": "6.0.1",
        "rimraf": "6.1.3",
        "tailwindcss": "4.3.1",
        "tsx": "4.22.4",
        "typescript": "6.0.3"
    }
}
