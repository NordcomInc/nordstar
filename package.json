{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "nordstar",
    "type": "module",
    "version": "0.0.0",
    "description": "An opinionated component library for building human-centric user interfaces.",
    "private": true,
    "main": "index.js",
    "engines": {
        "node": ">=22"
    },
    "workspaces": [
        "packages/core/*",
        "packages/components/*",
        "docs"
    ],
    "scripts": {
        "prepare": "husky",
        "dev": "concurrently -i pnpm:dev:* --",
        "dev:docs": "pnpm build:packages && concurrently -i -k pnpm:dev:packages \"turbo dev --filter=@nordcom/nordstar-docs\"",
        "dev:packages": "turbo dev --filter=!@nordcom/nordstar-docs --filter=!@nordcom/nordstar --filter=!@nordcom/nordstar-system",
        "build": "turbo build",
        "build:docs": "turbo build --filter=@nordcom/nordstar-docs",
        "build:packages": "turbo build --filter=!@nordcom/nordstar-docs",
        "typecheck": "turbo typecheck",
        "format": "concurrently -i pnpm:format:*",
        "format:lint": "biome lint --write .",
        "format:format": "biome format --write .",
        "format:check": "biome check --write --unsafe .",
        "lint": "biome lint .",
        "lint-staged": "pnpm exec lint-staged",
        "ci": "biome ci .",
        "test": "vitest run --coverage",
        "clean": "turbo clean --filter=!@nordcom/nordstar-docs && concurrently -i pnpm:clean:*",
        "clean:test": "rimraf -v -I -g test-results playwright-report coverage",
        "clean:repo": "rm -rf dist coverage .turbo .next .tsbuildinfo *.log",
        "clean:docs": "turbo clean --filter=@nordcom/nordstar-docs",
        "create": "plop --plopfile ./plop/plopfile.js",
        "create:component": "plop --plopfile ./plop/plopfile.js component",
        "version": "changeset version",
        "postversion": "pnpm install",
        "version:unstable": "changeset version --snapshot unstable",
        "release": "changeset publish",
        "release:unstable": "changeset publish --no-git-tag --tag unstable",
        "changeset": "changeset"
    },
    "author": {
        "name": "Filiph Sandström",
        "email": "filfat@hotmail.se",
        "url": "https://github.com/filiphsps/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/NordcomInc/nordstar.git"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/NordcomInc/nordstar/issues"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,css,json}": [
            "biome check --no-errors-on-unmatched --write --unsafe",
            "biome check --no-errors-on-unmatched"
        ]
    },
    "homepage": "https://nordcominc.github.io/nordstar/",
    "devDependencies": {
        "@biomejs/biome": "2.4.15",
        "@changesets/changelog-github": "0.7.0",
        "@changesets/cli": "2.31.0",
        "@changesets/types": "6.1.0",
        "@codecov/vite-plugin": "2.0.1",
        "@happy-dom/global-registrator": "20.9.0",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/node": "24.12.4",
        "@types/react-dom": "19.2.3",
        "@types/react": "19.2.15",
        "@vitejs/plugin-react": "6.0.2",
        "@vitest/coverage-v8": "4.1.7",
        "chalk": "5.6.2",
        "concurrently": "9.2.1",
        "glob": "^13.0.6",
        "happy-dom": "20.9.0",
        "husky": "9.1.7",
        "inquirer-directory": "2.2.0",
        "inquirer": "13.4.3",
        "lint-staged": "17.0.5",
        "magic-string": "0.30.21",
        "plop": "4.0.5",
        "react-dom": "19.2.6",
        "react": "19.2.6",
        "rimraf": "6.1.3",
        "rollup-preserve-directives": "1.1.3",
        "sass": "1.99.0",
        "strip-ansi": "7.2.0",
        "tailwindcss": "4.3.0",
        "turbo": "2.9.14",
        "typescript-plugin-css-modules": "5.2.0",
        "typescript": "6.0.3",
        "vite-plugin-dts": "5.0.1",
        "vite-plugin-lib-inject-css": "2.2.2",
        "vite": "8.0.13",
        "vitest": "4.1.7"
    },
    "packageManager": "pnpm@11.1.3"
}
