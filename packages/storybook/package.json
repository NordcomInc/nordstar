{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/nordstar-storybook",
    "version": "0.0.73",
    "main": "src/index.ts",
    "sideEffects": true,
    "private": true,
    "files": [
        "dist",
        "CHANGELOG.md",
        "README.md"
    ],
    "scripts": {
        "build": "storybook build --disable-telemetry",
        "dev": "storybook dev -p 3001 --disable-telemetry",
        "clean": "rm -rf dist coverage storybook-static .turbo .next *.tsbuildinfo *.log"
    },
    "dependencies": {
        "@nordcom/nordstar": "workspace:*",
        "react-dom": "19.2.5",
        "react": "19.2.5",
        "storybook": "10.3.6"
    },
    "devDependencies": {
        "@joshwooding/vite-plugin-react-docgen-typescript": "0.7.0",
        "@nordcom/prettier": "0.1.1",
        "@storybook/addon-controls": "9.0.3",
        "@storybook/addon-docs": "10.3.6",
        "@storybook/addon-essentials": "8.6.14",
        "@storybook/blocks": "8.6.14",
        "@storybook/core": "8.6.14",
        "@storybook/manager-api": "8.6.14",
        "@storybook/react-vite": "10.3.6",
        "@storybook/react": "10.3.6",
        "@storybook/theming": "8.6.14",
        "@types/node": "24.0.10",
        "@types/react-dom": "19.2.3",
        "@types/react": "19.2.14",
        "@tailwindcss/postcss": "4.2.4",
        "@vitejs/plugin-react": "6.0.1",
        "prettier": "3.8.3",
        "storybook-addon-react-docgen": "1.2.44",
        "storybook-addon-sass-postcss": "0.4.0",
        "storybook-dark-mode": "5.0.0",
        "tailwindcss": "4.2.4",
        "typescript": "6.0.3",
        "vite-plugin-dts": "5.0.0",
        "vite-tsconfig-paths": "6.1.1",
        "vite": "8.0.10"
    }
}
