{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/nordstar-dropdown-menu",
    "type": "module",
    "version": "0.2.0",
    "description": "A menu of actions triggered by a button.",
    "files": [
        "dist",
        "CHANGELOG.md",
        "README.md"
    ],
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "scripts": {
        "build": "tsc && vite build",
        "dev": "vite build --watch",
        "clean": "rm -rf dist coverage .turbo .next *.tsbuildinfo *.log",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "nordstar",
        "nordcom",
        "component",
        "react",
        "dropdown-menu",
        "menu",
        "nordstar-dropdown-menu"
    ],
    "author": {
        "name": "Filiph Sandström",
        "email": "filfat@hotmail.se",
        "url": "https://github.com/filiphsps/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/NordcomInc/nordstar.git",
        "directory": "packages/components/dropdown-menu"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/NordcomInc/nordstar/issues"
    },
    "homepage": "https://nordcominc.github.io/nordstar/docs/components/dropdown-menu/",
    "dependencies": {
        "@nordcom/nordstar-system": "workspace:*",
        "@radix-ui/react-dropdown-menu": "2.1.21"
    },
    "peerDependencies": {
        "react": ">=19",
        "react-dom": ">=19"
    },
    "devDependencies": {
        "@types/node": "25.9.5",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "react": "19.2.8",
        "react-dom": "19.2.7",
        "typescript": "6.0.3",
        "vite": "8.1.5",
        "vite-plugin-dts": "5.0.3"
    }
}
