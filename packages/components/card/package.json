{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/nordstar-card",
    "type": "module",
    "version": "0.0.75",
    "description": "Card is a consistent card-like container for blocks of content.",
    "files": [
        "dist",
        "CHANGELOG.md",
        "README.md"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "module": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public",
        "main": "dist/index.js",
        "module": "dist/index.js",
        "types": "dist/index.d.ts",
        "exports": {
            ".": {
                "import": "./dist/index.js",
                "module": "./dist/index.js",
                "require": null,
                "types": "./dist/index.d.ts"
            },
            "./dist/index.css": "./dist/index.css",
            "./package.json": "./package.json"
        }
    },
    "sideEffects": false,
    "scripts": {
        "build": "tsc && vite build",
        "dev": "vite build --watch",
        "clean": "rm -rf dist coverage .turbo .next *.tsbuildinfo *.log",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "nordstar",
        "nordcom",
        "component",
        "react",
        "card",
        "nordstar-card"
    ],
    "author": {
        "name": "Filiph Sandström",
        "email": "filfat@hotmail.se",
        "url": "https://github.com/filiphsps/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/NordcomInc/nordstar.git",
        "directory": "packages/components/card"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/NordcomInc/nordstar/issues"
    },
    "homepage": "https://nordcominc.github.io/nordstar/docs/components/card/",
    "dependencies": {
        "@nordcom/nordstar-system": "workspace:*",
        "class-variance-authority": "0.7.1"
    },
    "peerDependencies": {
        "react": ">=19",
        "react-dom": ">=19"
    },
    "devDependencies": {
        "@types/node": "24.12.4",
        "@types/react-dom": "19.2.3",
        "@types/react": "19.2.15",
        "react-dom": "19.2.6",
        "react": "19.2.6",
        "typescript": "6.0.3",
        "vite-plugin-dts": "5.0.1",
        "vite": "8.0.13"
    }
}
