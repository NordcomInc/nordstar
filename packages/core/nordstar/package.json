{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/nordstar",
    "type": "module",
    "version": "0.0.75",
    "description": "An opinionated component library for building human-centric user interfaces.",
    "files": [
        "dist",
        "CHANGELOG.md",
        "README.md"
    ],
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "style": "./dist/tailwind.css",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./styles.css": "./dist/styles.css",
        "./tailwind.css": "./dist/tailwind.css",
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": [
        "**/*.css"
    ],
    "keywords": [
        "nordstar",
        "nordcom"
    ],
    "author": {
        "name": "Filiph Sandström",
        "email": "filfat@hotmail.se",
        "url": "https://github.com/filiphsps/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/NordcomInc/nordstar.git",
        "directory": "packages/core/nordstar"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/NordcomInc/nordstar/issues"
    },
    "homepage": "https://nordcominc.github.io/nordstar/",
    "scripts": {
        "build": "pnpm build:compile && pnpm build:scripts",
        "build:compile": "vite build",
        "build:scripts": "concurrently -i pnpm:build:scripts:* --",
        "build:scripts:build-css": "node scripts/build-css.mjs",
        "clean": "rm -rf dist coverage .turbo .next *.tsbuildinfo *.log",
        "dev": "vite build --watch",
        "typecheck": "tsc --noEmit",
        "verify:pack": "rm -f /tmp/nordcom-nordstar-*.tgz && pnpm pack --pack-destination /tmp && publint /tmp/nordcom-nordstar-*.tgz",
        "verify:pack:attw": "rm -f /tmp/nordcom-nordstar-*.tgz && pnpm pack --pack-destination /tmp && attw /tmp/nordcom-nordstar-*.tgz"
    },
    "dependencies": {
        "@radix-ui/react-switch": "1.3.0",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "hex-to-hsl": "1.0.2",
        "tailwind-merge": "3.6.0"
    },
    "peerDependencies": {
        "react": ">=19",
        "react-dom": ">=19",
        "tailwindcss": ">=4"
    },
    "peerDependenciesMeta": {
        "tailwindcss": {
            "optional": true
        }
    },
    "devDependencies": {
        "@nordcom/nordstar-accented": "workspace:*",
        "@nordcom/nordstar-button": "workspace:*",
        "@nordcom/nordstar-card": "workspace:*",
        "@nordcom/nordstar-details": "workspace:*",
        "@nordcom/nordstar-header": "workspace:*",
        "@nordcom/nordstar-heading": "workspace:*",
        "@nordcom/nordstar-input": "workspace:*",
        "@nordcom/nordstar-kbd": "workspace:*",
        "@nordcom/nordstar-label": "workspace:*",
        "@nordcom/nordstar-separator": "workspace:*",
        "@nordcom/nordstar-switch": "workspace:*",
        "@nordcom/nordstar-system": "workspace:*",
        "@nordcom/nordstar-view": "workspace:*",
        "@tailwindcss/cli": "4.3.1",
        "@types/node": "25.9.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "tailwindcss": "4.3.1",
        "typescript": "6.0.3",
        "vite": "8.0.16",
        "vite-plugin-dts": "5.0.2"
    }
}
