{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/nordstar",
    "type": "module",
    "version": "0.0.73",
    "description": "An opinionated component library for building human-centric user interfaces.",
    "files": [
        "dist",
        "CHANGELOG.md",
        "README.md"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "style":   "./dist/tailwind.css",
            "import":  "./dist/index.js",
            "module":  "./dist/index.js",
            "types":   "./dist/index.d.ts"
        },
        "./styles.css":   "./dist/styles.css",
        "./tailwind.css": "./dist/tailwind.css",
        "./*": {
            "import": ["./dist/*.js"],
            "module": ["./dist/*.js"],
            "types":  ["./dist/*.d.ts"]
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "keywords": [
        "nordstar",
        "nordcom"
    ],
    "author": {
        "name": "Filiph Sandström",
        "email": "filfat@hotmail.se",
        "url": "https://github.com/filiphsps/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/NordcomInc/nordstar.git",
        "directory": "packages/core/nordstar"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/NordcomInc/nordstar/issues"
    },
    "homepage": "https://nordcominc.github.io/nordstar/",
    "scripts": {
        "build": "tsc && vite build && node scripts/build-css.mjs",
        "dev": "vite build --watch",
        "clean": "rm -rf dist coverage storybook-static .turbo .next *.tsbuildinfo *.log",
        "typecheck": "tsc --noEmit",
        "lint": "concurrently -i pnpm:lint:*",
        "lint:prettier": "prettier --check \"./**/src/**/*.{cjs,mjs,ts,tsx}\"",
        "format": "concurrently -i pnpm:format:*",
        "format:prettier": "prettier --write \"./**/src/**/*.{cjs,mjs,ts,tsx}\""
    },
    "dependencies": {
        "@nordcom/nordstar-accented": "workspace:*",
        "@nordcom/nordstar-button": "workspace:*",
        "@nordcom/nordstar-card": "workspace:*",
        "@nordcom/nordstar-details": "workspace:*",
        "@nordcom/nordstar-header": "workspace:*",
        "@nordcom/nordstar-heading": "workspace:*",
        "@nordcom/nordstar-input": "workspace:*",
        "@nordcom/nordstar-label": "workspace:*",
        "@nordcom/nordstar-system": "workspace:*",
        "@nordcom/nordstar-view": "workspace:*",
        "class-variance-authority": "0.7.0"
    },
    "peerDependencies": {
        "react": ">=19",
        "react-dom": ">=19",
        "tailwindcss": ">=4"
    },
    "peerDependenciesMeta": {
        "tailwindcss": { "optional": true }
    },
    "devDependencies": {
        "@nordcom/prettier": "0.1.1",
        "@tailwindcss/cli": "^4",
        "@types/node": "24.0.10",
        "@types/react-dom": "19.1.6",
        "@types/react": "19.1.8",
        "prettier": "3.8.3",
        "react-dom": "19.2.5",
        "react": "19.2.5",
        "tailwindcss": "4.2.4",
        "typescript": "6.0.3",
        "vite-plugin-dts": "5.0.0",
        "vite-tsconfig-paths": "6.1.1",
        "vite": "8.0.10"
    }
}
