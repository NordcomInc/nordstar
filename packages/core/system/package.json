{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/nordstar-system",
    "type": "module",
    "version": "0.0.74",
    "description": "Utilities used by all of the Nordstar Components, shouldn't be used directly outside of the Nordstar library.",
    "files": [
        "dist",
        "CHANGELOG.md",
        "README.md"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": [
                "./dist/index.js"
            ],
            "module": [
                "./dist/index.js"
            ],
            "types": [
                "./dist/index.d.ts"
            ]
        },
        "./*": {
            "import": [
                "./dist/*.js"
            ],
            "module": [
                "./dist/*.js"
            ],
            "types": [
                "./dist/*.d.ts"
            ]
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "keywords": [
        "nordstar",
        "nordcom"
    ],
    "author": {
        "name": "Filiph Sandström",
        "email": "filfat@hotmail.se",
        "url": "https://github.com/filiphsps/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/NordcomInc/nordstar.git",
        "directory": "packages/core/system"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/NordcomInc/nordstar/issues"
    },
    "homepage": "https://nordcominc.github.io/nordstar/docs/customization/system/",
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "clean": "rm -rf dist coverage .turbo .next *.tsbuildinfo *.log",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "clsx": "2.1.1",
        "hex-to-hsl": "1.0.2",
        "tailwind-merge": "3.5.0"
    },
    "peerDependencies": {
        "react": ">=19",
        "react-dom": ">=19"
    },
    "devDependencies": {
        "@types/node": "25.6.1",
        "@types/prop-types": "15.7.15",
        "@types/react-dom": "19.2.3",
        "@types/react": "19.2.14",
        "react-dom": "19.2.6",
        "react": "19.2.6",
        "typescript": "6.0.3",
        "vite": "8.0.11"
    }
}
